#!/bin/bash
set -euo pipefail

MC_VERSION="1.21.11"
FABRIC_LOADER="0.19.1"
INSTALLER="1.1.1"
DIR="/srv/minecraft/fabric"

echo "== creating dir =="
mkdir -p "$DIR"
cd "$DIR"

echo "== downloading fabric server =="
wget -q -O fabric-server.jar \
"https://meta.fabricmc.net/v2/versions/loader/$MC_VERSION/$FABRIC_LOADER/$INSTALLER/server/jar"

echo "== first run =="
java -Xmx2G -jar fabric-server.jar || true

echo "== eula =="
sed -i 's/eula=false/eula=true/' eula.txt

mkdir -p mods world/datapacks

echo "== mods =="

wget -q -O fabric-api.jar \
"https://cdn.modrinth.com/data/P7dR8mSH/versions/i5tSkVBH/fabric-api-0.141.3%2B1.21.11.jar"

wget -q -O tectonic.jar \
"https://cdn.modrinth.com/data/lWDHr9jE/versions/7olSYFxL/tectonic-3.0.19-fabric-1.21.11.jar"

wget -q -O lithium.jar \
"https://cdn.modrinth.com/data/gvQqBUqZ/versions/Ow7wA0kG/lithium-fabric-0.21.4%2Bmc1.21.11.jar"

wget -q -O ferritecore.jar \
"https://cdn.modrinth.com/data/uXXizFIs/versions/Ii0gP3D8/ferritecore-8.2.0-fabric.jar"

wget -q -O chunky.jar \
"https://cdn.modrinth.com/data/fALzjamp/versions/1CpEkmcD/Chunky-Fabric-1.4.55.jar"

echo "== terralith datapack =="
wget -q -O world/datapacks/terralith.zip \
"https://cdn.modrinth.com/data/8oi3bsk5/versions/vVdNToqE/Terralith_1.21.11_v2.6.1_Fabric.jar"

echo "== start script =="
cat > start.sh <<'EOF'
#!/bin/bash

nice -n -5 java -Xms12G -Xmx12G \
-XX:+UseG1GC \
-XX:+ParallelRefProcEnabled \
-XX:MaxGCPauseMillis=200 \
-XX:G1ReservePercent=20 \
-XX:+UnlockExperimentalVMOptions \
-XX:+DisableExplicitGC \
-XX:+AlwaysPreTouch \
-XX:ParallelGCThreads=$(nproc) \
-XX:ConcGCThreads=$(nproc) \
-jar fabric-server.jar nogui
EOF

chmod +x start.sh

echo "== done =="
echo "run: ./start.sh"
